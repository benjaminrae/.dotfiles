{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "WebFetch",
      "WebSearch",
      "Bash(ls *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git show *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git rebase *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh issue *)",
      "Bash(cat <<*)",
      "Bash(make *)"
    ]
  },
  "enabledMcpjsonServers": [
    "mcp-atlassian"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-use-bash.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"\\(.title // \"Claude Code\")\\n\\(.body // \"Needs your attention\")\"' | { read -r title; read -r body; osascript -e \"display notification \\\"$body\\\" with title \\\"$title\\\" sound name \\\"Funk\\\"\"; }",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "dark-daltonized",
  "preferredNotifChannel": "terminal_bell",
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
