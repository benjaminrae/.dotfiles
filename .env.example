# Secrets for this dotfiles repo. Copy to `.env` (gitignored) and fill in real values.
# `.env` is sourced by zsh/.zshrc so these are exported when you launch claude,
# which expands ${VAR} references in claude/.mcp.json at load time.

# Atlassian API token (used for both Jira and Confluence in claude/.mcp.json).
# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
export ATLASSIAN_API_TOKEN=
